# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://bi_user:bi_pass@localhost:5432/bi_platform
DATABASE_POOL_SIZE=20

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Service ─────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ─── Next.js Frontend ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Python Analytics Service ────────────────────────────────
ANALYTICS_SERVICE_URL=http://localhost:8100
ANALYTICS_HOST=0.0.0.0
ANALYTICS_PORT=8100

# ─── AI / LLM ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── Observability ───────────────────────────────────────────
LOG_LEVEL=debug
